        local function updateCurrentPosition()
            local character = game.Players.LocalPlayer.Character
            if character and character:FindFirstChild("HumanoidRootPart") then
                local position = character.HumanoidRootPart.Position
                CurrentLabel.Text = string.format("当前位置: (%.1f, %.1f, %.1f)", 
                    position.X, position.Y, position.Z)
                
                if XInput.Text == "0" and YInput.Text == "0" and ZInput.Text == "0" then
                    XInput.Text = tostring(math.floor(position.X))
                    YInput.Text = tostring(math.floor(position.Y))
                    ZInput.Text = tostring(math.floor(position.Z))
                end
            end
        end
        
        TeleportBtn.MouseButton1Click:Connect(function()
            local x = tonumber(XInput.Text)
            local y = tonumber(YInput.Text)
            local z = tonumber(ZInput.Text)
            
            if x and y and z then
                local character = game.Players.LocalPlayer.Character
                if character and character:FindFirstChild("HumanoidRootPart") then
                    character.HumanoidRootPart.CFrame = CFrame.new(x, y, z)
                    WindUI:Notify({
                        Title = "坐标传送",
                        Content = string.format("已传送到坐标 (%.1f, %.1f, %.1f)", x, y, z),
                        Icon = "map-pin",
                        Duration = 3
                    })
                else
                    WindUI:Notify({
                        Title = "传送失败",
                        Content = "角色未找到",
                        Icon = "error",
                        Duration = 3
                    })
                end
            else
                WindUI:Notify({
                    Title = "输入错误",
                    Content = "请输入有效的坐标数字",
                    Icon = "error",
                    Duration = 3
                })
            end
        end)
        
        CloseBtn.MouseButton1Click:Connect(function()
            CoordinateGui:Destroy()
            _G.CoordinateGUI = nil
        end)
        
        game:GetService("RunService").RenderStepped:Connect(updateCurrentPosition)
        
        CoordinateGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")
        _G.CoordinateGUI = CoordinateGui
